{{!-- templates/actors/parts/talents.hbs --}}
<section class="tab sheet-body" data-tab="talents" data-group="sheet">

  <div class="skills-header">
    <h2 class="section-title">{{localize "GHRPG.Sheet.Talents"}}</h2>
    <div class="skill-actions-bar">
      <button type="button" class="add-btn" data-action="createItem" data-type="talent">
        <i class="fas fa-plus"></i> Add Talent
      </button>
    </div>
  </div>

  <p class="section-note">{{localize "GHRPG.Sheet.TalentsHint"}}</p>

  {{#if talents.length}}
  <div class="items-list talents-list">
    {{#each talents}}
    <div class="item-row talent-row" data-item-id="{{id}}">

      {{!-- Initiative badge --}}
      <div class="skill-init-col">
        {{#if system.passive}}
          <span class="passive-badge" title="Passive Talent">P</span>
        {{else}}
          <span class="init-badge">{{system.initiative}}</span>
        {{/if}}
      </div>

      {{!-- Name & type --}}
      <div class="skill-main-col">
        <div class="skill-name-row">
          <span class="skill-name">{{name}}</span>
          {{#if system.passive}}<span class="passive-tag">Passive</span>{{/if}}
        </div>
        {{#if system.passive}}
        <div class="skill-actions-preview">
          <span>{{system.description}}</span>
        </div>
        {{else}}
        <div class="skill-actions-preview">
          <span class="action-primary"><strong>▶</strong> {{system.primaryAction}}</span>
          {{#if system.secondaryAction}}
          <span class="action-secondary"><strong>▷</strong> {{system.secondaryAction}}</span>
          {{/if}}
        </div>
        {{/if}}
      </div>

      {{!-- Level --}}
      <div class="skill-level-col">
        <span class="level-badge">Lvl {{system.level}}</span>
      </div>

      {{!-- Controls --}}
      <div class="skill-controls">
        {{#unless system.passive}}
        <button type="button" class="btn-sm btn-use" data-action="useTalent" title="Post talent to chat">
          <i class="fas fa-play"></i> Use
        </button>
        {{/unless}}
        <button type="button" class="btn-icon" data-action="editItem" title="Edit"><i class="fas fa-pen"></i></button>
        <button type="button" class="btn-icon btn-danger" data-action="deleteItem" title="Delete"><i class="fas fa-trash"></i></button>
      </div>
    </div>
    {{/each}}
  </div>
  {{else}}
  <div class="empty-notice">
    <p>No talents yet.</p>
    <button type="button" class="add-btn large" data-action="createItem" data-type="talent">
      <i class="fas fa-plus"></i> Add Talent
    </button>
  </div>
  {{/if}}

</section>
