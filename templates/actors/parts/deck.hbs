{{!-- templates/actors/parts/deck.hbs --}}
<section class="tab sheet-body deck-tab" data-tab="deck" data-group="sheet">

  <div class="deck-main-layout">

    {{!-- ─── Left column: draw + contents ─── --}}
    <div class="deck-left-col">

      {{!-- Draw controls --}}
      <div class="section-block">
        <h2 class="section-title">Draw</h2>
        <div class="draw-buttons">
          <button type="button" class="draw-btn draw-normal" data-action="drawCard" data-mode="normal">
            <i class="fas fa-hand"></i> {{localize "GHRPG.Sheet.DrawNormal"}}
          </button>
          <button type="button" class="draw-btn draw-advantage" data-action="drawCard" data-mode="advantage">
            <i class="fas fa-angles-up"></i> {{localize "GHRPG.Sheet.DrawAdvantage"}}
          </button>
          <button type="button" class="draw-btn draw-disadvantage" data-action="drawCard" data-mode="disadvantage">
            <i class="fas fa-angles-down"></i> {{localize "GHRPG.Sheet.DrawDisadvantage"}}
          </button>
        </div>
        <div class="deck-counters-row">
          <span class="counter-chip"><i class="fas fa-layer-group"></i> Draw: <strong>{{deckCount}}</strong></span>
          <span class="counter-chip"><i class="fas fa-clone"></i> Discard: <strong>{{discardCount}}</strong></span>
          <span class="bless-chip"><i class="fas fa-person"></i> Bless: {{system.modifierDeck.blessCount}}/6</span>
          <span class="curse-chip"><i class="fas fa-bolt"></i> Curse: {{system.modifierDeck.curseCount}}/6</span>
        </div>
        <div class="deck-management">
          <button type="button" class="reshuffle-btn" data-action="reshuffleDeck">
            <i class="fas fa-shuffle"></i> {{localize "GHRPG.Sheet.ReshuffleBtn"}}
          </button>
          {{#if (eq deckCount 0)}}
          <button type="button" class="reshuffle-btn init-btn" data-action="initializeDeck">
            <i class="fas fa-layer-group"></i> {{localize "GHRPG.Sheet.InitializeBtn"}}
          </button>
          {{/if}}
        </div>
      </div>

      {{!-- Draw pile (collapsible) --}}
      <div class="section-block collapsible-section" data-collapsed="true">
        <h2 class="section-title collapsible-header" data-action="toggleSection">
          <i class="fas fa-chevron-right collapse-icon"></i>
          Draw Pile
          <span class="collapse-hint">({{deckCount}} cards)</span>
        </h2>
        <div class="collapsible-body" style="display:none">
          {{#if deckComposition.length}}
          <div class="card-composition">
            {{#each deckComposition}}
            <div class="comp-row card-type-{{type}}">
              <span class="comp-count">×{{count}}</span>
              {{#if (eq type "normal")}}
              <span class="comp-mods">
                <span class="atk-mod">Atk {{#if (gt atkMod 0)}}+{{/if}}{{atkMod}}</span>
                <span class="attr-mod">Attr +{{attrMod}}</span>
              </span>
              {{/if}}
              {{#if (eq type "null")}}    <span class="comp-badge badge-null">MISS</span>{{/if}}
              {{#if (eq type "critical")}}<span class="comp-badge badge-crit">CRIT ×2</span>{{/if}}
              {{#if (eq type "bless")}}   <span class="comp-badge badge-bless"><i class="fas fa-person"></i> Bless</span>{{/if}}
              {{#if (eq type "curse")}}   <span class="comp-badge badge-curse"><i class="fas fa-bolt"></i> Curse</span>{{/if}}
            </div>
            {{/each}}
          </div>
          {{else}}
          <p class="empty-notice">Draw pile is empty.</p>
          {{/if}}
        </div>
      </div>

      {{!-- Discard pile (collapsible) --}}
      <div class="section-block collapsible-section" data-collapsed="true">
        <h2 class="section-title collapsible-header" data-action="toggleSection">
          <i class="fas fa-chevron-right collapse-icon"></i>
          Discard Pile
          <span class="collapse-hint">({{discardCount}} cards)</span>
        </h2>
        <div class="collapsible-body" style="display:none">
          {{#if discardList.length}}
          <div class="discard-pile">
            {{#each discardList}}
            <div class="discard-row card-type-{{type}}{{#if @first}} discard-top{{/if}}">
              <span class="discard-row-label">
                {{#if (eq type "normal")}}Atk {{#if (gt atkMod 0)}}+{{/if}}{{atkMod}} / Attr +{{attrMod}}
                {{else}}{{label}}{{/if}}
              </span>
              {{#if (eq type "null")}}    <span class="comp-badge badge-null">MISS</span>{{/if}}
              {{#if (eq type "critical")}}<span class="comp-badge badge-crit">CRIT</span>{{/if}}
              {{#if (eq type "bless")}}   <span class="comp-badge badge-bless"><i class="fas fa-person"></i> Bless</span>{{/if}}
              {{#if (eq type "curse")}}   <span class="comp-badge badge-curse"><i class="fas fa-bolt"></i> Curse</span>{{/if}}
              {{#if @first}}<span class="top-badge">latest</span>{{/if}}
            </div>
            {{/each}}
          </div>
          {{else}}
          <p class="empty-notice">No cards discarded yet.</p>
          {{/if}}
        </div>
      </div>

    </div>

    {{!-- ─── Right column: last drawn + add/remove ─── --}}
    <div class="deck-right-col">

      {{!-- Last Drawn --}}
      <div class="section-block">
        <h2 class="section-title">{{localize "GHRPG.Sheet.LastDrawn"}}</h2>
        {{#if lastDrawn}}
        <div class="last-drawn-block">
          {{#if (eq lastDrawn.mode "advantage")}}
          <div class="draw-mode-badge mode-advantage"><i class="fas fa-angles-up"></i> {{localize "GHRPG.Sheet.DrawAdvantage"}}</div>
          {{else if (eq lastDrawn.mode "disadvantage")}}
          <div class="draw-mode-badge mode-disadvantage"><i class="fas fa-angles-down"></i> {{localize "GHRPG.Sheet.DrawDisadvantage"}}</div>
          {{/if}}
          {{#if (gt lastDrawn.allDrawn.length 1)}}
          <div class="all-drawn-cards">
            {{#each lastDrawn.allDrawn}}
            <div class="drawn-card-mini card-type-{{type}} {{#if (eq id ../lastDrawn.applied.id)}}applied{{/if}}">
              {{#if (eq type "normal")}}
                <span class="dcm-atk">{{#if (gt atkMod 0)}}+{{/if}}{{atkMod}}</span>
                <span class="dcm-attr-badge">{{attrMod}}</span>
              {{else if (eq type "null")}}<span class="dcm-special">MISS</span>
              {{else if (eq type "critical")}}<span class="dcm-special">CRIT</span>
              {{else}}<span class="dcm-special">{{label}}</span>{{/if}}
              <span class="applied-marker">{{#if (eq id ../lastDrawn.applied.id)}}✓{{else}}✗{{/if}}</span>
            </div>
            {{/each}}
          </div>
          {{/if}}
          <div class="mod-card card-type-{{lastDrawn.applied.type}}">
            <div class="mod-card-inner">
              <div class="mod-card-center">
                {{#if (eq lastDrawn.applied.type "normal")}}
                  <div class="mod-card-circle">
                    <span class="mod-atk-value">{{#if (gt lastDrawn.applied.atkMod 0)}}+{{/if}}{{lastDrawn.applied.atkMod}}</span>
                  </div>
                {{else if (eq lastDrawn.applied.type "null")}}
                  <div class="mod-card-circle card-circle-null"><span class="mod-special-value">✕</span></div>
                {{else if (eq lastDrawn.applied.type "critical")}}
                  <div class="mod-card-circle card-circle-crit"><span class="mod-special-value">×2</span></div>
                {{else if (eq lastDrawn.applied.type "bless")}}
                  <div class="mod-card-circle card-circle-bless"><span class="mod-special-value">✦</span></div>
                {{else if (eq lastDrawn.applied.type "curse")}}
                  <div class="mod-card-circle card-circle-curse"><span class="mod-special-value">✧</span></div>
                {{/if}}
              </div>
              <div class="mod-card-bottom">
                <div class="mod-card-portrait"><img src="{{actor.img}}" alt="{{actor.name}}" /></div>
                {{#if (eq lastDrawn.applied.type "normal")}}
                <div class="mod-card-hex"><span class="mod-attr-value">{{lastDrawn.applied.attrMod}}</span></div>
                {{/if}}
              </div>
              {{#if (eq lastDrawn.applied.type "null")}}    <div class="mod-card-flavor">Miss · Critical failure · Reshuffles deck</div>{{/if}}
              {{#if (eq lastDrawn.applied.type "critical")}}<div class="mod-card-flavor">Double damage · Auto-success · Reshuffles deck</div>{{/if}}
              {{#if (eq lastDrawn.applied.type "bless")}}   <div class="mod-card-flavor">Treated as Critical</div>{{/if}}
              {{#if (eq lastDrawn.applied.type "curse")}}   <div class="mod-card-flavor">Treated as Null</div>{{/if}}
              {{#if lastDrawn.applied.effects.length}}
              <div class="mod-card-effects">
                {{#each lastDrawn.applied.effects}}
                <span class="mod-card-effect effect-{{type}}{{#if optional}} effect-optional{{/if}}">
                  {{#if (eq type "poison")}}<i class="fas fa-skull-crossbones"></i>
                  {{else if (eq type "wound")}}<i class="fas fa-droplet"></i>
                  {{else if (eq type "muddle")}}<i class="fas fa-cloud"></i>
                  {{else if (eq type "stun")}}<i class="fas fa-star"></i>
                  {{else if (eq type "immobilize")}}<i class="fas fa-lock"></i>
                  {{else if (eq type "pierce")}}<i class="fas fa-crosshairs"></i>
                  {{else if (eq type "push")}}<i class="fas fa-arrow-up"></i>
                  {{else if (eq type "pull")}}<i class="fas fa-arrow-down"></i>
                  {{else if (eq type "heal")}}<i class="fas fa-heart"></i>
                  {{else if (eq type "strengthen")}}<i class="fas fa-shield"></i>
                  {{else if (eq type "curse")}}<i class="fas fa-bolt"></i>
                  {{else if (eq type "bless")}}<i class="fas fa-person"></i>
                  {{/if}}
                  {{capitalize type}}{{#if value}} {{value}}{{/if}}{{#if optional}} <span class="effect-opt-tag">opt</span>{{/if}}
                </span>
                {{/each}}
              </div>
              {{/if}}
            </div>
          </div>
        </div>
        {{else}}
        <p class="empty-notice">{{localize "GHRPG.Sheet.NoCardDrawn"}}.</p>
        {{/if}}
      </div>

      {{!-- Add / Remove Cards --}}
      <div class="section-block">
        <h2 class="section-title">Add / Remove Cards</h2>

        {{!-- Bless / Curse row --}}
        <div class="bless-curse-row">
          <div class="bc-group">
            <span class="bc-label bless-label"><i class="fas fa-person"></i> Bless</span>
            <span class="bc-count">{{system.modifierDeck.blessCount}}/6</span>
            <button type="button" class="bc-btn bc-minus" data-action="removeBless"
              {{#if (eq system.modifierDeck.blessCount 0)}}disabled{{/if}}>−</button>
            <button type="button" class="bc-btn bc-plus" data-action="addBless"
              {{#if (eq system.modifierDeck.blessCount 6)}}disabled{{/if}}>+</button>
          </div>
          <div class="bc-group">
            <span class="bc-label curse-label"><i class="fas fa-bolt"></i> Curse</span>
            <span class="bc-count">{{system.modifierDeck.curseCount}}/6</span>
            <button type="button" class="bc-btn bc-minus" data-action="removeCurse"
              {{#if (eq system.modifierDeck.curseCount 0)}}disabled{{/if}}>−</button>
            <button type="button" class="bc-btn bc-plus" data-action="addCurse"
              {{#if (eq system.modifierDeck.curseCount 6)}}disabled{{/if}}>+</button>
          </div>
        </div>

        {{!-- Remove from deck (collapsible) --}}
        <div class="collapsible-section" data-collapsed="true" style="margin-top:8px">
          <div class="collapsible-header card-mgmt-header" data-action="toggleSection">
            <i class="fas fa-chevron-right collapse-icon"></i>
            <span>Remove card from draw pile</span>
          </div>
          <div class="collapsible-body" style="display:none; margin-top:6px">
            {{#if deckRemoveList.length}}
            <div class="card-remove-list">
              {{#each deckRemoveList}}
              <div class="card-remove-row card-type-{{type}}">
                <span class="crr-origin {{#if isDefault}}origin-default{{else}}origin-added{{/if}}"
                      title="{{#if isDefault}}Default deck card{{else}}Added card{{/if}}">
                  {{#if isDefault}}<i class="fas fa-layer-group"></i>{{else}}<i class="fas fa-plus-circle"></i>{{/if}}
                </span>
                <span class="crr-label">
                  {{#if (eq type "normal")}}Atk {{#if (gt atkMod 0)}}+{{/if}}{{atkMod}} / Attr +{{attrMod}}
                  {{else if (eq type "bless")}}<i class="fas fa-person"></i> Bless
                  {{else if (eq type "curse")}}<i class="fas fa-bolt"></i> Curse
                  {{else}}{{label}}{{/if}}
                </span>
                {{#if (eq type "null")}}    <span class="comp-badge badge-null">MISS</span>{{/if}}
                {{#if (eq type "critical")}}<span class="comp-badge badge-crit">CRIT</span>{{/if}}
                {{#each effects}}
                <span class="crr-effect effect-{{type}}">{{type}}{{#if value}} {{value}}{{/if}}{{#if optional}}?{{/if}}</span>
                {{/each}}
                <button type="button" class="card-remove-btn" data-action="removeCard" data-card-id="{{id}}"
                        title="Remove from deck">
                  <i class="fas fa-minus"></i>
                </button>
              </div>
              {{/each}}
            </div>
            {{else}}
            <p class="empty-notice">Draw pile is empty.</p>
            {{/if}}
          </div>
        </div>

        {{!-- Removed defaults (collapsible, only if any) --}}
        {{#if removedDefaults.length}}
        <div class="collapsible-section" data-collapsed="true" style="margin-top:8px">
          <div class="collapsible-header card-mgmt-header" data-action="toggleSection">
            <i class="fas fa-chevron-right collapse-icon"></i>
            <span>Restore removed cards</span>
            <span class="collapse-hint">({{removedDefaults.length}} removed)</span>
          </div>
          <div class="collapsible-body" style="display:none; margin-top:6px">
            <div class="card-remove-list">
              {{#each removedDefaults}}
              <div class="card-remove-row card-type-{{type}} removed-card">
                <span class="crr-label">
                  {{#if (eq type "normal")}}Atk {{#if (gt atkMod 0)}}+{{/if}}{{atkMod}} / Attr +{{attrMod}}
                  {{else}}{{label}}{{/if}}
                </span>
                <button type="button" class="card-restore-btn" data-action="restoreCard" data-card-id="{{id}}"
                        title="Shuffle back into draw pile">
                  <i class="fas fa-rotate-left"></i> Restore
                </button>
              </div>
              {{/each}}
            </div>
          </div>
        </div>
        {{/if}}

        {{!-- Add custom card --}}
        <div class="add-custom-card" style="margin-top:8px">
          <div class="collapsible-section" data-collapsed="true">
            <div class="collapsible-header card-mgmt-header" data-action="toggleSection">
              <i class="fas fa-chevron-right collapse-icon"></i>
              <span>Add custom card</span>
            </div>
            <div class="collapsible-body" style="display:none; margin-top:6px">
              <div class="custom-card-form">
                <div class="custom-input-row">
                  <label class="custom-input-label">Attack mod</label>
                  <input type="number" name="customAtk" value="0" class="custom-mod-input" />
                </div>
                <div class="custom-input-row">
                  <label class="custom-input-label">Attr mod</label>
                  <input type="number" name="customAttr" value="0" class="custom-mod-input" />
                </div>
                <div class="custom-form-divider">Effect <span class="custom-form-optional">(optional)</span></div>
                <div class="custom-input-row">
                  <label class="custom-input-label">Type</label>
                  <select name="customEffectType" class="custom-mod-input custom-effect-select">
                    <option value="">— none —</option>
                    <option value="poison">Poison</option>
                    <option value="wound">Wound</option>
                    <option value="muddle">Muddle</option>
                    <option value="stun">Stun</option>
                    <option value="immobilize">Immobilize</option>
                    <option value="pierce">Pierce</option>
                    <option value="push">Push</option>
                    <option value="pull">Pull</option>
                    <option value="heal">Heal</option>
                    <option value="strengthen">Strengthen</option>
                    <option value="curse">Curse</option>
                    <option value="bless">Bless</option>
                  </select>
                </div>
                <div class="custom-input-row custom-effect-value-row" style="display:none">
                  <label class="custom-input-label">Value</label>
                  <input type="number" name="customEffectValue" value="" placeholder="e.g. 3" class="custom-mod-input" />
                </div>
                <div class="custom-input-row">
                  <label class="custom-input-label">Optional?</label>
                  <label class="custom-checkbox-label">
                    <input type="checkbox" name="customEffectOptional" />
                    <span>Player chooses to apply</span>
                  </label>
                </div>
                <button type="button" class="card-restore-btn" data-action="addCustomCard">
                  <i class="fas fa-plus"></i> Add to deck
                </button>
              </div>
            </div>
          </div>
        </div>

      </div>{{!-- end Add/Remove section --}}

    </div>{{!-- end right col --}}

  </div>

  {{!-- ─── Perks Section ─── --}}
  <div class="deck-perks-section">
    <div class="deck-perks-header">
      <h3 class="deck-perks-title"><i class="fas fa-list-check"></i> Perks</h3>
      <div class="perk-points-display">
        {{#if selectedClass}}
        <span class="perk-points-available {{#if (lte availablePerkPoints 0)}}perk-points-empty{{/if}}">
          {{usedPerkPoints}}/{{totalPerkPoints}} perks used
        </span>
        <span class="perk-points-bonus" title="Bonus perks">
          Base: {{basePerkPoints}} + Bonus:
          <input type="number" name="system.bonusPerks" value="{{system.bonusPerks}}"
                 min="0" class="bonus-perks-input" />
        </span>
        {{else}}
        <span class="perk-no-class">{{localize "GHRPG.Notifications.NoAncestrySelected"}}</span>
        {{/if}}
      </div>
    </div>

    {{#if selectedClass}}
    {{#if classPerks.length}}
    <div class="perks-list">
      {{#each classPerks}}
      <div class="perk-entry {{#if (lte ../availablePerkPoints 0)}}perk-points-exhausted{{/if}}">
        <div class="perk-entry-label">{{label}}</div>
        <div class="perk-checkboxes">
          {{#times maxTimes}}
          <button type="button"
                  class="perk-checkbox {{#if (gt (add 1 this) ../takenCount)}}perk-unchecked{{else}}perk-checked{{/if}}"
                  data-action="togglePerk"
                  data-perk-id="{{../id}}"
                  data-perk-slot="{{this}}"
                  title="{{../label}} ({{add 1 this}}/{{../maxTimes}})">
            <i class="fas {{#if (gt (add 1 this) ../takenCount)}}fa-square{{else}}fa-check-square{{/if}}"></i>
          </button>
          {{/times}}
        </div>
      </div>
      {{/each}}
    </div>
    {{else}}
    <p class="ancestry-empty-hint">{{localize "GHRPG.Sheet.NoPerks"}}</p>
    {{/if}}
    {{/if}}

  </div>

</section>
