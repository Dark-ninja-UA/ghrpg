{{!-- templates/actors/parts/biography.hbs --}}
<section class="tab sheet-body" data-tab="biography" data-group="sheet">

  <div class="bio-layout">
    <div class="bio-field">
      <label class="bio-label">{{localize "GHRPG.Sheet.PersonalQuest"}}</label>
      <textarea name="system.personalQuest" class="bio-textarea quest-textarea"
                placeholder="Your mercenary's retirement goal...">{{system.personalQuest}}</textarea>
    </div>

    <div class="bio-field">
      <label class="bio-label">Biography</label>
      {{editor system.biography target="system.biography" button=true editable=isOwner}}
    </div>

    <div class="bio-field">
      <label class="bio-label">Notes</label>
      <textarea name="system.notes" class="bio-textarea notes-textarea"
                placeholder="Session notes, reminders...">{{system.notes}}</textarea>
    </div>
  </div>

</section>
