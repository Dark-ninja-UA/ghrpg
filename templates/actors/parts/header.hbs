{{!-- templates/actors/parts/header.hbs --}}
<div class="sheet-header-wrap">
<header class="sheet-header">
  <div class="portrait-wrap">
    <img class="actor-portrait" src="{{actor.img}}" alt="{{actor.name}}" data-action="editImage" title="Click to change portrait" />
    <div class="portrait-token-btn" data-action="configureToken" title="Prototype Token"><i class="fas fa-user-circle"></i></div>
  </div>
  <div class="header-fields">
    <div class="name-row">
      <input class="actor-name" type="text" name="name" value="{{actor.name}}" placeholder="Character Name" />
    </div>
    <div class="identity-row">
      <div class="field-group">
        <label>{{localize "GHRPG.Sheet.Ancestry"}}</label>
        <select name="system.ancestry">
          {{selectOptions ancestryOptions selected=system.ancestry}}
        </select>
      </div>
      <div class="field-group">
        <label>{{localize "GHRPG.Sheet.Class"}}</label>
        <select name="system.class">
          {{selectOptions classOptions selected=system.class}}
        </select>
      </div>
      <div class="field-group field-narrow">
        <label>{{localize "GHRPG.Sheet.Level"}}</label>
        <input type="number" name="system.level" value="{{system.level}}" min="1" max="9" />
      </div>
      <div class="field-group">
        <label>{{localize "GHRPG.Sheet.Faction"}}</label>
        <select name="system.faction">
          {{selectOptions factionOptions selected=system.faction}}
        </select>
      </div>
    </div>
    <div class="vitals-row">
      {{!-- HP --}}
      <div class="vital-block hp-block">
        <label>{{localize "GHRPG.Sheet.HP"}}</label>
        <div class="hp-display">
          <input type="number" name="system.hp.value" value="{{system.hp.value}}" min="0" max="{{system.hp.max}}" class="hp-current" />
          <span class="hp-sep">/</span>
          <input type="number" name="system.hp.max"   value="{{system.hp.max}}"   min="1" class="hp-max" />
        </div>
        <div class="hp-bar-wrap">
          <div class="hp-bar" style="width: {{hpPct}}%"></div>
        </div>
      </div>
      {{!-- Gold --}}
      <div class="vital-block">
        <label>{{localize "GHRPG.Sheet.Gold"}}</label>
        <input type="number" name="system.gold" value="{{system.gold}}" min="0" class="gold-input" />
      </div>

    </div>
  </div>
</header>

{{!-- Tab navigation --}}
<nav class="sheet-tabs tabs" data-group="sheet">
  {{#each tabs}}
  <a class="item {{cssClass}}" data-action="tab" data-tab="{{id}}" data-group="{{group}}">
    <i class="{{icon}}"></i> {{label}}
  </a>
  {{/each}}
</nav>
</div>
