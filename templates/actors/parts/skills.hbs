{{!-- templates/actors/parts/skills.hbs --}}
<section class="tab sheet-body" data-tab="skills" data-group="sheet">

  {{!-- Ancestry info banner --}}
  {{#if selectedAncestry}}
  <div class="ancestry-banner">
    <i class="fas fa-dna"></i>
    <span class="ancestry-banner-name">{{selectedAncestry.name}}</span>
    <span class="ancestry-banner-hint">— ancestry skills are marked with <i class="fas fa-dna"></i></span>
  </div>
  {{else}}
  <div class="ancestry-banner ancestry-banner-empty">
    <i class="fas fa-dna"></i> No ancestry selected — set one in the header to see ancestry skills.
  </div>
  {{/if}}

  <div class="skills-header">
    <h2 class="section-title">
      Skills
      <span class="skill-counts">
        Prepared: {{preparedSkillCount}}/6
      </span>
    </h2>
    <div class="skill-actions-bar">
      <button type="button" class="add-btn" data-action="createItem" data-type="skill">
        <i class="fas fa-plus"></i> Add Skill
      </button>
    </div>
  </div>

  {{#if skills.length}}
  <div class="items-list skills-list">
    {{#each skills}}
    <div class="item-row skill-row
      {{#if system.expended}} skill-expended{{/if}}
      {{#if system.lost}} skill-lost{{/if}}
      {{#if system.prepared}} skill-prepared{{/if}}"
      data-item-id="{{id}}">

      {{!-- Prepared toggle --}}
      <div class="skill-prep-col">
        <button type="button"
                class="prep-toggle {{#if system.prepared}}prepared{{/if}}"
                data-action="togglePrepared"
                title="{{#if system.prepared}}Unprepare{{else}}Prepare{{/if}}">
          <i class="fas {{#if system.prepared}}fa-check-circle{{else}}fa-circle{{/if}}"></i>
        </button>
      </div>

      {{!-- Initiative badge --}}
      <div class="skill-init-col">
        <span class="init-badge">{{system.initiative}}</span>
      </div>

      {{!-- Name & source --}}
      <div class="skill-main-col">
        <div class="skill-name-row">
          <span class="skill-name">{{name}}</span>
          <span class="skill-source-badge {{system.sourceType}}">
            {{#if (eq system.sourceType "ancestry")}}A{{else}}C{{/if}}
          </span>
          {{#if (includes ../ancestrySkillIds id)}}<span class="ancestry-link-badge" title="Linked to {{../selectedAncestry.name}}"><i class="fas fa-dna"></i></span>{{/if}}
          {{#if system.lost}}<span class="lost-badge">LOST</span>{{/if}}
          {{#if system.expended}}<span class="expended-badge">Expended</span>{{/if}}
        </div>
        <div class="skill-actions-preview">
          <span class="action-primary"><strong>▶</strong> {{system.primaryAction}}</span>
          {{#if system.secondaryAction}}
          <span class="action-secondary"><strong>▷</strong> {{system.secondaryAction}}</span>
          {{/if}}
        </div>
      </div>

      {{!-- Skill level --}}
      <div class="skill-level-col">
        <span class="level-badge">Lvl {{system.level}}</span>
      </div>

      {{!-- Controls --}}
      <div class="skill-controls">
        {{#if system.prepared}}
          {{#if system.expended}}
            <button type="button" class="btn-sm btn-recover" data-action="recoverSkill" title="Recover skill">
              <i class="fas fa-undo"></i>
            </button>
          {{else}}
            <button type="button" class="btn-sm btn-use" data-action="useSkill" title="Use skill">
              <i class="fas fa-play"></i> Use
            </button>
          {{/if}}
        {{/if}}
        <button type="button" class="btn-icon" data-action="editItem" title="Edit"><i class="fas fa-pen"></i></button>
        <button type="button" class="btn-icon btn-danger" data-action="deleteItem" title="Delete"><i class="fas fa-trash"></i></button>
      </div>
    </div>
    {{/each}}
  </div>
  {{else}}
  <div class="empty-notice">
    <p>No skills yet. Add class and ancestry skills to get started.</p>
    <button type="button" class="add-btn large" data-action="createItem" data-type="skill">
      <i class="fas fa-plus"></i> Add Skill
    </button>
  </div>
  {{/if}}

</section>
