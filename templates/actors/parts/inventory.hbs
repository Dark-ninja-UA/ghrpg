{{!-- templates/actors/parts/inventory.hbs --}}
<section class="tab sheet-body" data-tab="inventory" data-group="sheet">

  <div class="skills-header">
    <h2 class="section-title">{{localize "GHRPG.Sheet.Inventory"}}</h2>
    <div class="skill-actions-bar">
      <button type="button" class="add-btn" data-action="createItem" data-type="equipment">
        <i class="fas fa-plus"></i> Add Item
      </button>
    </div>
  </div>

  <p class="section-note">Max 5 additional items beyond equipped slots. Equipped: Head, Body, Feet, up to 2×Hand, 2×Small.</p>

  {{#if equipment.length}}
  <div class="items-list inventory-list">
    {{#each equipment}}
    <div class="item-row equipment-row {{#if system.equipped}}equipped{{/if}} {{#if system.expended}}expended{{/if}}"
         data-item-id="{{id}}">

      <div class="equip-slot-badge slot-{{system.slot}}" title="Slot: {{system.slot}}">
        {{#if (eq system.slot "head")}}🪖{{/if}}
        {{#if (eq system.slot "body")}}🎽{{/if}}
        {{#if (eq system.slot "feet")}}👢{{/if}}
        {{#if (eq system.slot "hand")}}⚔{{/if}}
        {{#if (eq system.slot "small")}}💍{{/if}}
      </div>

      <div class="skill-main-col">
        <div class="skill-name-row">
          <span class="skill-name">{{name}}</span>
          <span class="rarity-badge rarity-{{system.rarity}}">{{capitalize system.rarity}}</span>
          {{#if system.equipped}}<span class="equipped-badge">Equipped</span>{{/if}}
          {{#if system.expended}}<span class="expended-badge">Expended</span>{{/if}}
          {{#if system.consumable}}<span class="consumable-badge">×{{system.uses.max}}</span>{{/if}}
        </div>
        <div class="skill-actions-preview">{{system.effect}}</div>
      </div>

      <div class="skill-level-col">
        <span class="gold-value">{{system.goldValue}}g</span>
      </div>

      <div class="skill-controls">
        <button type="button" class="btn-icon" data-action="editItem" title="Edit"><i class="fas fa-pen"></i></button>
        <button type="button" class="btn-icon btn-danger" data-action="deleteItem" title="Delete"><i class="fas fa-trash"></i></button>
      </div>
    </div>
    {{/each}}
  </div>
  {{else}}
  <div class="empty-notice">
    <p>No items yet.</p>
    <button type="button" class="add-btn large" data-action="createItem" data-type="equipment">
      <i class="fas fa-plus"></i> Add Item
    </button>
  </div>
  {{/if}}

</section>
