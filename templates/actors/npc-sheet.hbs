{{!-- templates/actors/npc-sheet.hbs --}}
<div class="npc-sheet-wrap">
<header class="sheet-header npc-header">
  <img class="actor-portrait small" src="{{actor.img}}" alt="{{actor.name}}" />
  <div class="header-fields">
    <input class="actor-name" type="text" name="name" value="{{actor.name}}" />
    <div class="npc-stats">
      <div class="npc-stat">
        <label>HP</label>
        <input type="number" name="system.hp.value" value="{{system.hp.value}}" min="0" max="{{system.hp.max}}" />
        <span>/</span>
        <input type="number" name="system.hp.max"   value="{{system.hp.max}}"   min="1" />
      </div>
      <div class="npc-stat">
        <label>Move</label>
        <input type="number" name="system.move"   value="{{system.move}}"   min="0" />
      </div>
      <div class="npc-stat">
        <label>Attack</label>
        <input type="number" name="system.attack" value="{{system.attack}}" min="0" />
      </div>
    </div>
  </div>
</header>

<div class="sheet-body npc-body">
  {{!-- Attributes --}}
  <div class="section-block">
    <h3 class="section-title">Attributes</h3>
    <div class="attributes-grid small">
      {{#each attributes}}
      <div class="attribute-item">
        <span class="attr-abbr">{{abbr}}</span>
        <input class="attr-value" type="number" name="system.attributes.{{key}}.value" value="{{value}}" min="0" max="7" />
        <button type="button" class="attr-roll-btn" data-action="rollAttribute" data-attribute="{{key}}" title="Roll {{label}}">
          <i class="fas fa-dice"></i>
        </button>
      </div>
      {{/each}}
    </div>
  </div>

  {{!-- Conditions --}}
  <div class="section-block">
    <h3 class="section-title">Conditions</h3>
    <div class="conditions-row">
      {{#each conditions}}
      <button type="button" class="condition-btn negative {{#if active}}active{{/if}}"
              data-action="toggleCondition" data-condition="{{key}}" title="{{label}}">
        <span class="cond-label">{{label}}</span>
      </button>
      {{/each}}
    </div>
  </div>

  {{!-- Deck --}}
  <div class="section-block">
    <h3 class="section-title">GM Modifier Deck</h3>
    <div class="deck-counters small">
      <span>Draw: {{deckCount}}</span>
      <span>Discard: {{discardCount}}</span>
    </div>
    <div class="draw-buttons compact">
      <button type="button" class="draw-btn" data-action="drawCard">Draw Card</button>
      <button type="button" class="draw-btn" data-action="reshuffleDeck">Reshuffle</button>
    </div>
  </div>

  {{!-- Biography --}}
  <div class="section-block">
    <h3 class="section-title">Notes</h3>
    <textarea name="system.biography" class="bio-textarea">{{system.biography}}</textarea>
  </div>
</div>
</div>
