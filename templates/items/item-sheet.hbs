{{!-- templates/items/item-sheet.hbs --}}
<div class="item-sheet-wrap">
<header class="sheet-header item-header">
  <img class="item-img" src="{{item.img}}" alt="{{item.name}}" />
  <div class="header-fields">
    <input class="item-name" type="text" name="name" value="{{item.name}}" placeholder="Item Name" />
    <div class="item-type-badge">{{localize (concat "GHRPG.ItemTypes." item.type)}}</div>
  </div>
</header>

<div class="sheet-body item-body">

  {{!-- ─── SKILL ─── --}}
  {{#if isSkill}}
  <div class="skill-form">
    <div class="form-row">
      <div class="form-group">
        <label>{{localize "GHRPG.Sheet.Source"}}</label>
        <select name="system.sourceType">
          {{selectOptions sourceOptions selected=system.sourceType}}
        </select>
      </div>
      <div class="form-group narrow">
        <label>{{localize "GHRPG.Sheet.Level"}}</label>
        <input type="number" name="system.level" value="{{system.level}}" min="1" max="9" />
      </div>
      <div class="form-group narrow">
        <label>{{localize "GHRPG.Sheet.Initiative"}}</label>
        <input type="number" name="system.initiative" value="{{system.initiative}}" min="1" max="99" />
      </div>
    </div>
    <div class="form-group">
      <label>{{localize "GHRPG.Sheet.PrimaryAction"}}</label>
      <textarea name="system.primaryAction" class="action-textarea"
                placeholder="e.g. Attack 3; if Fire, add Wound">{{system.primaryAction}}</textarea>
    </div>
    <div class="form-group">
      <label>{{localize "GHRPG.Sheet.SecondaryAction"}}</label>
      <textarea name="system.secondaryAction" class="action-textarea"
                placeholder="e.g. Move 2. Heal 1, yourself.">{{system.secondaryAction}}</textarea>
    </div>
    <div class="form-row">
      <div class="form-group check-group">
        <label><input type="checkbox" name="system.lost" {{#if system.lost}}checked{{/if}} /> {{localize "GHRPG.Sheet.Lost"}}</label>
      </div>
      <div class="form-group check-group">
        <label><input type="checkbox" name="system.prepared" {{#if system.prepared}}checked{{/if}} /> {{localize "GHRPG.Sheet.SkillPrepared"}}</label>
      </div>
      <div class="form-group check-group">
        <label><input type="checkbox" name="system.expended" {{#if system.expended}}checked{{/if}} /> {{localize "GHRPG.Sheet.Expended"}}</label>
      </div>
      <div class="form-group check-group">
        <label><input type="checkbox" name="system.noExpend" {{#if system.noExpend}}checked{{/if}} title="Skill posts to chat but is never marked as expended" /> {{localize "GHRPG.Sheet.NotExpendedOnUse"}}</label>
      </div>
    </div>
    <div class="form-group">
      <label>Description / Notes</label>
      <textarea name="system.description" class="bio-textarea">{{system.description}}</textarea>
    </div>
  </div>
  {{/if}}

  {{!-- ─── TALENT ─── --}}
  {{#if isTalent}}
  <div class="skill-form">
    <div class="form-row">
      <div class="form-group narrow">
        <label>{{localize "GHRPG.Sheet.Level"}}</label>
        <input type="number" name="system.level" value="{{system.level}}" min="1" max="9" />
      </div>
      <div class="form-group narrow">
        <label>{{localize "GHRPG.Sheet.Initiative"}}</label>
        <input type="number" name="system.initiative" value="{{system.initiative}}" min="1" max="99" />
      </div>
      <div class="form-group narrow">
        <label>{{localize "GHRPG.Sheet.UpgradeAtLevel"}}</label>
        <input type="number" name="system.upgradeLevel" value="{{system.upgradeLevel}}" min="1" max="9" />
      </div>
      <div class="form-group check-group">
        <label><input type="checkbox" name="system.passive" {{#if system.passive}}checked{{/if}} /> {{localize "GHRPG.Sheet.PassiveTalent"}}</label>
      </div>
    </div>
    {{#unless system.passive}}
    <div class="form-group">
      <label>{{localize "GHRPG.Sheet.PrimaryAction"}}</label>
      <textarea name="system.primaryAction" class="action-textarea">{{system.primaryAction}}</textarea>
    </div>
    <div class="form-group">
      <label>{{localize "GHRPG.Sheet.SecondaryAction"}}</label>
      <textarea name="system.secondaryAction" class="action-textarea">{{system.secondaryAction}}</textarea>
    </div>
    {{/unless}}
    <div class="form-group">
      <label>{{localize "GHRPG.Sheet.Description"}}</label>
      <textarea name="system.description" class="bio-textarea">{{system.description}}</textarea>
    </div>
    <div class="form-group check-group">
      <label><input type="checkbox" name="system.noExpend" {{#if system.noExpend}}checked{{/if}} title="Talent posts to chat but is never marked as expended" /> {{localize "GHRPG.Sheet.NotExpendedOnUse"}}</label>
    </div>
  </div>
  {{/if}}

  {{!-- ─── BACKGROUND ─── --}}
  {{#if isBackground}}
  <div class="skill-form">
    <div class="form-row">
      <div class="form-group">
        <label>Category</label>
        <select name="system.category">
          {{selectOptions categoryOptions selected=system.category}}
        </select>
      </div>
      <div class="form-group narrow">
        <label>Bonus</label>
        <input type="number" name="system.bonus" value="{{system.bonus}}" min="2" max="4" />
      </div>
      <div class="form-group check-group">
        <label><input type="checkbox" name="system.master" {{#if system.master}}checked{{/if}} /> {{localize "GHRPG.Sheet.MasterBackground"}}</label>
      </div>
    </div>
    {{#if system.master}}
    <div class="form-group">
      <label>{{localize "GHRPG.Sheet.Prerequisite"}}</label>
      <input type="text" name="system.prerequisite" value="{{system.prerequisite}}" placeholder="Required background" />
    </div>
    {{/if}}
    <div class="form-group">
      <label>{{localize "GHRPG.Sheet.Description"}}</label>
      <textarea name="system.description" class="bio-textarea">{{system.description}}</textarea>
    </div>
    <div class="form-group check-group">
      <label><input type="checkbox" name="system.expended" {{#if system.expended}}checked{{/if}} /> {{localize "GHRPG.Sheet.Expended"}}</label>
    </div>
  </div>
  {{/if}}

  {{!-- ─── EQUIPMENT ─── --}}
  {{#if isEquipment}}
  <div class="skill-form">
    <div class="form-row">
      <div class="form-group">
        <label>{{localize "GHRPG.Sheet.Slot"}}</label>
        <select name="system.slot">
          {{selectOptions slotOptions selected=system.slot}}
        </select>
      </div>
      <div class="form-group">
        <label>{{localize "GHRPG.Sheet.Rarity"}}</label>
        <select name="system.rarity">
          {{selectOptions rarityOptions selected=system.rarity}}
        </select>
      </div>
      <div class="form-group narrow">
        <label>Gold Value</label>
        <input type="number" name="system.goldValue" value="{{system.goldValue}}" min="0" />
      </div>
    </div>
    <div class="form-group">
      <label>Effect</label>
      <textarea name="system.effect" class="action-textarea">{{system.effect}}</textarea>
    </div>
    <div class="form-row">
      <div class="form-group narrow">
        <label>Uses per Scene</label>
        <input type="number" name="system.uses.max" value="{{system.uses.max}}" min="0" />
      </div>
      <div class="form-group narrow">
        <label>Current Uses</label>
        <input type="number" name="system.uses.value" value="{{system.uses.value}}" min="0" />
      </div>
    </div>
    <div class="form-row checkboxes">
      <label><input type="checkbox" name="system.equipped"   {{#if system.equipped}}checked{{/if}} /> {{localize "GHRPG.Sheet.Equipped"}}</label>
      <label><input type="checkbox" name="system.consumable" {{#if system.consumable}}checked{{/if}} /> {{localize "GHRPG.Sheet.Consumable"}}</label>
      <label><input type="checkbox" name="system.alchemic"   {{#if system.alchemic}}checked{{/if}} /> {{localize "GHRPG.Sheet.Alchemic"}}</label>
      <label><input type="checkbox" name="system.expended"   {{#if system.expended}}checked{{/if}} />   Expended</label>
    </div>
    <div class="form-group">
      <label>{{localize "GHRPG.Sheet.CraftingType"}}</label>
      <input type="text" name="system.craftingType" value="{{system.craftingType}}" placeholder="e.g. Blacksmithing" />
    </div>
    <div class="form-group">
      <label>{{localize "GHRPG.Sheet.Description"}}</label>
      <textarea name="system.description" class="bio-textarea">{{system.description}}</textarea>
    </div>
  </div>
  {{/if}}

  {{!-- ─── ANCESTRY ─── --}}
  {{#if isAncestry}}
  <div class="ancestry-form">

    <div class="form-group">
      <label>Traits & Passives</label>
      <textarea name="system.traits" class="action-textarea"
                placeholder="e.g. Darkvision. You can see in darkness up to 30 feet.">{{system.traits}}</textarea>
    </div>

    <div class="form-group">
      <label>{{localize "GHRPG.Sheet.Description"}}</label>
      <textarea name="system.description" class="bio-textarea"
                placeholder="Describe this ancestry…">{{system.description}}</textarea>
    </div>

    {{!-- Linked Skills --}}
    <div class="ancestry-links-section">
      <h3 class="ancestry-links-title">
        <i class="fas fa-scroll"></i> {{localize "GHRPG.Sheet.AncestrySkills"}}
        <span class="ancestry-link-hint">Link skills that belong to this ancestry</span>
      </h3>

      {{#if linkedSkills.length}}
      <div class="ancestry-link-list">
        {{#each linkedSkills}}
        <div class="ancestry-link-row">
          <img class="ancestry-link-img" src="{{img}}" />
          <span class="ancestry-link-name">{{name}}</span>
          <button type="button" class="btn-icon btn-danger" data-action="unlinkSkill" data-item-id="{{id}}" title="Remove link">
            <i class="fas fa-times"></i>
          </button>
        </div>
        {{/each}}
      </div>
      {{else}}
      <p class="ancestry-empty-hint">No skills linked yet. Drag a Skill item here, or use the button below.</p>
      {{/if}}

      <div class="ancestry-link-drop" data-drop-type="skill">
        <i class="fas fa-plus-circle"></i> {{localize "GHRPG.Sheet.DropSkill"}}
      </div>
    </div>

    {{!-- Linked Talents --}}
    <div class="ancestry-links-section">
      <h3 class="ancestry-links-title">
        <i class="fas fa-star"></i> {{localize "GHRPG.Sheet.AncestryTalents"}}
        <span class="ancestry-link-hint">Link talents that belong to this ancestry</span>
      </h3>

      {{#if linkedTalents.length}}
      <div class="ancestry-link-list">
        {{#each linkedTalents}}
        <div class="ancestry-link-row">
          <img class="ancestry-link-img" src="{{img}}" />
          <span class="ancestry-link-name">{{name}}</span>
          <button type="button" class="btn-icon btn-danger" data-action="unlinkTalent" data-item-id="{{id}}" title="Remove link">
            <i class="fas fa-times"></i>
          </button>
        </div>
        {{/each}}
      </div>
      {{else}}
      <p class="ancestry-empty-hint">{{localize "GHRPG.Sheet.NoTalentsLinked"}}</p>
      {{/if}}

      <div class="ancestry-link-drop" data-drop-type="talent">
        <i class="fas fa-plus-circle"></i> {{localize "GHRPG.Sheet.DropTalent"}}
      </div>
    </div>

  </div>
  {{/if}}

  {{!-- ─── CLASS ─── --}}
  {{#if isClass}}
  <div class="ancestry-form">

    <div class="form-group">
      <label>{{localize "GHRPG.Sheet.Description"}}</label>
      <textarea name="system.description" class="bio-textarea"
                placeholder="Describe this class…">{{system.description}}</textarea>
    </div>

    {{!-- Starting Attributes --}}
    <div class="ancestry-links-section">
      <h3 class="ancestry-links-title">
        <i class="fas fa-chart-bar"></i> {{localize "GHRPG.Sheet.StartingAttributes"}}
        <span class="ancestry-link-hint">Mandatory bonuses applied at character creation</span>
      </h3>
      <div class="class-attr-grid">
        {{#each startingAttributes}}
        <div class="class-attr-item">
          <label class="class-attr-label">{{@key}}</label>
          <input type="number" name="system.startingAttributes.{{@key}}"
                 value="{{this}}" min="0" max="7" class="class-attr-input" />
        </div>
        {{/each}}
      </div>
    </div>

    {{!-- Linked Skills --}}
    <div class="ancestry-links-section">
      <h3 class="ancestry-links-title">
        <i class="fas fa-scroll"></i> {{localize "GHRPG.Sheet.ClassSkills"}}
        <span class="ancestry-link-hint">Drag skills to link them to this class</span>
      </h3>
      {{#if linkedSkills.length}}
      <div class="ancestry-link-list">
        {{#each linkedSkills}}
        <div class="ancestry-link-row">
          <img class="ancestry-link-img" src="{{img}}" />
          <span class="ancestry-link-name">{{name}}</span>
          <span class="ancestry-link-meta">Lvl {{system.level}}</span>
          <button type="button" class="btn-icon btn-danger" data-action="unlinkSkill" data-item-id="{{id}}" title="Remove link">
            <i class="fas fa-times"></i>
          </button>
        </div>
        {{/each}}
      </div>
      {{else}}
      <p class="ancestry-empty-hint">{{localize "GHRPG.Sheet.NoSkillsLinked"}}</p>
      {{/if}}
      <div class="ancestry-link-drop" data-drop-type="skill">
        <i class="fas fa-plus-circle"></i> {{localize "GHRPG.Sheet.DropSkill"}}
      </div>
    </div>

    {{!-- Linked Talents --}}
    <div class="ancestry-links-section">
      <h3 class="ancestry-links-title">
        <i class="fas fa-star"></i> {{localize "GHRPG.Sheet.ClassTalents"}}
        <span class="ancestry-link-hint">Drag talents to link them to this class</span>
      </h3>
      {{#if linkedTalents.length}}
      <div class="ancestry-link-list">
        {{#each linkedTalents}}
        <div class="ancestry-link-row">
          <img class="ancestry-link-img" src="{{img}}" />
          <span class="ancestry-link-name">{{name}}</span>
          <button type="button" class="btn-icon btn-danger" data-action="unlinkTalent" data-item-id="{{id}}" title="Remove link">
            <i class="fas fa-times"></i>
          </button>
        </div>
        {{/each}}
      </div>
      {{else}}
      <p class="ancestry-empty-hint">{{localize "GHRPG.Sheet.NoTalentsLinked"}}</p>
      {{/if}}
      <div class="ancestry-link-drop" data-drop-type="talent">
        <i class="fas fa-plus-circle"></i> {{localize "GHRPG.Sheet.DropTalent"}}
      </div>
    </div>

    {{!-- Perks --}}
    <div class="ancestry-links-section">
      <h3 class="ancestry-links-title">
        <i class="fas fa-list-check"></i> Perks
        <button type="button" class="add-btn" data-action="addPerk" style="margin-left:auto;font-size:10px;padding:2px 8px">
          <i class="fas fa-plus"></i> Add Perk
        </button>
      </h3>
      {{#if system.perks.length}}
      <div class="class-perks-list">
        {{#each system.perks}}
        <div class="class-perk-row">
          <span class="class-perk-label">{{label}}</span>
          <span class="class-perk-meta">×{{maxTimes}}</span>
          <button type="button" class="btn-icon" data-action="editPerk" data-perk-index="{{@index}}" title="Edit">
            <i class="fas fa-edit"></i>
          </button>
          <button type="button" class="btn-icon btn-danger" data-action="deletePerk" data-perk-index="{{@index}}" title="Delete">
            <i class="fas fa-trash"></i>
          </button>
        </div>
        {{/each}}
      </div>
      {{else}}
      <p class="ancestry-empty-hint">{{localize "GHRPG.Sheet.NoPerks"}}</p>
      {{/if}}
    </div>

  </div>
  {{/if}}

</div>
</div>
